{
    "howItWorks": {
        "title": "The Flow Is Simple",
        "description": "Look at the starting state, watch the conversation, look again at the end, then read the change.",
        "steps": {
            "step1": {
                "number": "01",
                "title": "See the start",
                "description": "Before the conversation begins, note how much judgment the human is still holding."
            },
            "step2": {
                "number": "02",
                "title": "Watch the exchange",
                "description": "During the conversation, watch for signals that judgment is being handed off or pulled back."
            },
            "step3": {
                "number": "03",
                "title": "See the end",
                "description": "After the interaction, compare the final state with the starting point."
            },
            "step4": {
                "number": "04",
                "title": "Read the shift",
                "description": "That tells you whether judgment moved toward AI, stayed shared, or returned to the human."
            }
        },
        "patterns": {
            "title": "Common Patterns",
            "gradual": {
                "name": "Gradual Delegation",
                "flow": "Human → Shared → AI",
                "signature": "Small positive values"
            },
            "rapid": {
                "name": "Rapid Delegation",
                "flow": "Human → AI (direct)",
                "signature": "Large positive spike"
            },
            "oscillation": {
                "name": "Oscillation",
                "flow": "Human ↔ AI",
                "signature": "Alternating +/−"
            },
            "reclamation": {
                "name": "Reclamation",
                "flow": "AI → Human recovery",
                "signature": "Negative values"
            },
            "collaborative": {
                "name": "Collaborative Stability",
                "flow": "Shared (maintained)",
                "signature": "Near zero"
            }
        }
    },
    "dataStructure": {
        "title": "Data Structures",
        "description": "Two core data structures power JDVP: the Judgment State Vector (JSV) for snapshots, and the Delegation Vector (DV) for measuring change.",
        "tabs": {
            "jsv": "JSV (State Vector)",
            "dv": "DV (Delegation Vector)"
        },
        "jsv": {
            "fields": {
                "judgment_holder": {
                    "name": "judgment_holder",
                    "description": "Who currently holds judgment authority (Agency)",
                    "type": "\"Human\" | \"AI\" | \"Shared\" | \"Undefined\""
                },
                "delegation_awareness": {
                    "name": "delegation_awareness",
                    "description": "Whether the human recognizes delegation is occurring (Metacognition)",
                    "type": "\"Explicit\" | \"Implicit\" | \"Absent\""
                },
                "cognitive_engagement": {
                    "name": "cognitive_engagement",
                    "description": "How much cognitive effort the human invests (Effort)",
                    "type": "\"Active\" | \"Reactive\" | \"Passive\""
                },
                "information_seeking": {
                    "name": "information_seeking",
                    "description": "Whether the human explores beyond what AI offers (Exploration)",
                    "type": "\"Active\" | \"Passive\" | \"None\""
                }
            }
        },
        "dv": {
            "polarityTitle": "Unified Polarity Convention",
            "polarity": {
                "positive": {
                    "symbol": "+",
                    "direction": "→ AI",
                    "description": "Movement toward AI delegation"
                },
                "zero": {
                    "symbol": "0",
                    "direction": "—",
                    "description": "No change"
                },
                "negative": {
                    "symbol": "−",
                    "direction": "→ Human",
                    "description": "Movement toward human retention"
                }
            },
            "fields": {
                "delta_judgment_holder": {
                    "name": "delta_judgment_holder",
                    "positive": "AI assumes",
                    "negative": "Human retains"
                },
                "delta_delegation_awareness": {
                    "name": "delta_delegation_awareness",
                    "positive": "Awareness decreases",
                    "negative": "Awareness increases"
                },
                "delta_cognitive_engagement": {
                    "name": "delta_cognitive_engagement",
                    "positive": "Less cognitive effort",
                    "negative": "More cognitive effort"
                },
                "delta_information_seeking": {
                    "name": "delta_information_seeking",
                    "positive": "Less exploration",
                    "negative": "More exploration"
                }
            },
            "important": {
                "label": "Important:",
                "text": "Aggregation and trend analysis are permitted. What is prohibited is using aggregated data to produce rankings, risk scores, or normative judgments about AI systems."
            }
        }
    }
}
